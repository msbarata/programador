algoritmo "SOMA NUMEROS 1 ATE 50 - USANDO REPITA ...ATÉ - V2"

// Funçăo :    Demonstrar o uso da estrutura de repetiçăo Repita ...Até
var
soma,contador: inteiro

inicio

 soma<-0
 contador <- 1
 repita
     soma<- soma + contador
     contador <- contador + 1
     //escreval(soma)
 ate contador >50

 escreva("A soma é: ",soma)
fimalgoritmo
