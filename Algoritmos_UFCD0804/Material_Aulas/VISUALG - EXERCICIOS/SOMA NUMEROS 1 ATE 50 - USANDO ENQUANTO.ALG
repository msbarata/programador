algoritmo "SOMA NUMEROS 1 ATE 50 - USANDO ENQUANTO"
// FunÓÐo :    Demonstrar o uso da estrutura de repetiÓÐo Enquanto

var
soma,contador: inteiro

inicio

 soma<-0
 contador <- 1
 enquanto contador <=50 faca
  soma<- soma + contador
  contador <- contador + 1
  //escreval(soma)
fimenquanto
escreva("A soma Õ: ",soma)
fimalgoritmo
