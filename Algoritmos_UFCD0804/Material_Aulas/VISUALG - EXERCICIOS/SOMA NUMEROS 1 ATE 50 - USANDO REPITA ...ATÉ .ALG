algoritmo "SOMA NUMEROS 1 ATE 50 - USANDO REPITA ...ATÉ "

// Funçăo :    Demonstrar o uso da estrutura de repetiçăo Repita ...Até
var
soma,contador: inteiro

inicio

 soma<-0
 contador <- 0
 repita
     contador <- contador + 1
     soma<- soma + contador

     //escreval(soma)
 ate contador >=50

 escreva("A soma é: ",soma)
fimalgoritmo
