algoritmo "SOMA NUMEROS 1 ATE 50 - USANDO ENQUANTO - V2"
// FunÓÐo :    Demonstrar o uso da estrutura de repetiÓÐo Enquanto

var
soma,contador: inteiro

inicio

 soma<-0
 contador <- 0
 enquanto contador <50 faca
  contador <- contador + 1
  soma<- soma + contador
  //escreval(soma)
 fimenquanto
 escreva("A soma Õ: ",soma)
fimalgoritmo
